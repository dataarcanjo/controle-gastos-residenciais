<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Build 100% offline: nenhuma dependência de pacotes NuGet externos é usada neste projeto
    (apenas os assemblies do shared framework do ASP.NET Core, já instalados junto com o SDK).
    Este arquivo remove a fonte remota padrão (nuget.org) para que "dotnet build/restore"
    funcione mesmo sem acesso à internet.
  -->
  <packageSources>
    <clear />
  </packageSources>
</configuration>
